# Copy to .env and fill in values from your Supabase project and local API URL.
# Never commit .env.

# local-integration | local-isolated
EXPO_PUBLIC_ENVIRONMENT=local-integration

# Supabase (Project Settings → API → anon/public key)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# FastAPI backend URL (use your machine's LAN IP when testing on a physical device)
EXPO_PUBLIC_BASE_URL=http://127.0.0.1:8000
