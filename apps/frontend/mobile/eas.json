{
  "cli": {
    "version": ">= 16.8.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "preview"
      },
      "node": {
        "install": {
          "args": ["--frozen-lockfile"]
        }
      },
      "channel": "preview",
      "command": "sh -c \"cd ../../.. && pnpm install --frozen-lockfile && pnpm turbo build --filter=@cwt/state... --filter=@cwt/schema... && pnpm --filter @cwt/frontend-mobile eas-build\"",
      "developmentClient": true
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
