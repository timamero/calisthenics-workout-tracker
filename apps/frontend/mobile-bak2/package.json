{
  "name": "mobile",
  "version": "0.1.0",
  "main": "index.ts",
  "scripts": {
    "dev": "expo start --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "check-types": "tsc --noEmit",
    "docker-build": "docker build -f Dockerfile.dev -t calisthenics-mobile-dev .",
    "docker-run": "docker run --rm -it -p 8081:8081 -p 19000:19000 -p 19001:19001 -v $(pwd):/mobile -w /mobile calisthenics-mobile-dev",
    "lint": "expo lint"
  },
  "dependencies": {
