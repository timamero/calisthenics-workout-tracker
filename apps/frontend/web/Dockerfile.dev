FROM node:20

# Configure PNPM environment
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"

# Enable corepack (makes pnpm available)
RUN corepack enable

# Create app directory
WORKDIR /web

# Copy package.json and root pnpm-lock.yaml for dependency installation
COPY apps/frontend/mobile/package.json ./
COPY pnpm-lock.yaml ./

# Install dependencies
RUN pnpm install

# Copy the rest of the app
COPY . .

# Expose Vite dev server port
EXPOSE 5173

# Start Vite dev server
CMD ["pnpm", "dev"]
