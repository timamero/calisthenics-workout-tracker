# Copy to .env and fill in values from your Supabase project and deployment URLs.
# Never commit .env.

APP_NAME=Calisthenics Workout Tracker
VERSION=0.1.0
DEBUG=True

# development | local | staging | production
ENVIRONMENT=development

# Supabase (Project Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_KEY_ID=your_supabase_jwt_key_id
SUPABASE_JWTK_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json

# CORS origins (used when ENVIRONMENT=local)
LOCAL_ORIGIN=http://127.0.0.1:8000
LOCAL_WEB_ORIGIN=http://localhost:5173
LOCAL_MOBILE_EXP_ORIGIN=https://your-expo-tunnel-url.exp.direct
LOCAL_MOBILE_ORIGIN=http://localhost:8081

# CORS origins (used when ENVIRONMENT=staging)
STAGING_ORIGIN=https://your-staging-api.example.com
STAGING_WEB_ORIGIN=https://your-staging-web.example.com
STAGING_MOBILE_ORIGIN=https://your-staging-mobile.example.com

# CORS origins (used when ENVIRONMENT=production)
PRODUCTION_ORIGIN=https://your-production-api.example.com
PRODUCTION_WEB_ORIGIN=https://your-production-web.example.com
PRODUCTION_MOBILE_ORIGIN=https://your-production-mobile.example.com

# Optional: used by backend tests
TEST_EMAIL=test@example.com
TEST_UID=00000000-0000-4000-8000-000000000001
