{
  "name": "@cwt/schema",
  "version": "0.1.0-alpha.1",
  "private": true,
  "description": "Schema validation for CWT",
  "type": "module",
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "format": "pnpm exec prettier . --write"
  },
  "exports": {
    "./common": {
      "types": "./dist/lib/common/index.d.ts",
      "default": "./dist/lib/common/index.js"
    },
    "./exercises": {
      "types": "./dist/lib/exercises/types.d.ts",
      "default": "./dist/lib/exercises/types.js"
    },
    "./exercises/schemas": {
      "types": "./dist/lib/exercises/schemas.index.d.ts",
      "default": "./dist/lib/exercises/schemas/index.js"
    },
    "./forms": {
      "types": "./dist/lib/forms/types.d.ts",
      "default": "./dist/lib/forms/types.js"
    },
    "./workouts": {
      "types": "./dist/lib/workouts/types.d.ts",
      "default": "./dist/lib/workouts/types.js"
    },
    "./leveragesAssists": {
      "types": "./dist/lib/leveragesAssists/types.d.ts",
      "default": "./dist/lib/leveragesAssists/types.js"
    },
    "./sampleSchema": {
      "types": "./dist/sampleSchema.d.ts",
      "default": "./dist/sampleSchema.js"
    }
  },
  "dependencies": {
    "@mantine/hooks": "^8.3.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "prettier": "3.6.2",
    "typescript": "~5.8.3"
  },
  "peerDependencies": {
    "react": "19.0.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  }
}
