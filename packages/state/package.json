{
  "name": "@cwt/state",
  "version": "0.1.0-alpha.1",
  "private": true,
  "description": "State management for CWT",
  "type": "module",
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc"
  },
  "exports": {
    "./counter": {
      "types": "./dist/counter.d.ts",
      "default": "./dist/counter.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "default": "./dist/auth.js"
    },
    "./stores": {
      "types": "./dist/lib/stores/index.d.ts",
      "default": "./dist/lib/stores/index.js"
    },
    "./exercises": {
      "types": "./dist/lib/slices/exercises/index.d.ts",
      "default": "./dist/lib/slices/exercises/index.js"
    }
  },
  "dependencies": {
    "@cwt/schema": "workspace:*",
    "@cwt/auth": "workspace:*",
    "immer": "^10.1.3",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "typescript": "~5.8.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  }
}
