{
  "name": "@cwt/state",
  "version": "0.1.0-alpha.1",
  "description": "State management for CWT",
  "type": "module",
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc"
  },
  "exports": {
    "./counter": {
      "types": "./src/counter.ts",
      "default": "./dist/counter.js"
    },
    "./exercises": {
      "types": "./src/exercises.ts",
      "default": "./dist/exercises.js"
    },
    "./auth": {
      "types": "./src/auth.ts",
      "default": "./dist/auth.js"
    },
    "./store": {
      "types": "./src/store.ts",
      "default": "./dist/store.js"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./dist/types.js"
    },
    "./slices/library": {
      "types": "./src/slices/library/*.ts",
      "default": "./dist/slices/library/*.js"
    }
  },
  "dependencies": {
    "zustand": "^5.0.5",
    "@cwt/schema": "workspace:*"
  },
  "devDependencies": {
    "typescript": "~5.8.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  }
}