{
  "name": "@cwt/api",
  "version": "0.1.0",
  "description": "API for CWT",
  "type": "module",
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc"
  },
  "exports": {
    "./exercisesService": {
      "types": "./src/exercisesService.ts",
      "default": "./dist/exercisesService.js"
    },
    "./projectData": {
      "types": "./src/projectData.ts",
      "default": "./dist/projectData.js"
    },
    "./protectedData": {
      "types": "./src/protectedData.ts",
      "default": "./dist/protectedData.js"
    }
  },
  "dependencies": {
    "@cwt/schema": "workspace:*"
  },
  "devDependencies": {
    "typescript": "~5.8.3"
  }
}