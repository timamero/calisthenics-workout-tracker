{
  "name": "@cwt/auth",
  "version": "0.1.0-alpha.1",
  "private": true,
  "description": "Authentication for CWT",
  "type": "module",
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc"
  },
  "exports": {
    "./supabase": {
      "types": "./src/supabase.ts",
      "default": "./dist/supabase.js"
    },
    "./createUser": {
      "types": "./src/createUser.ts",
      "default": "./dist/createUser.js"
    },
    "./session": {
      "types": "./src/session.ts",
      "default": "./dist/session.js"
    },
    "./signIn": {
      "types": "./src/signIn.ts",
      "default": "./dist/signIn.js"
    },
    "./signOut": {
      "types": "./src/signOut.ts",
      "default": "./dist/signOut.js"
    },
    "./user": {
      "types": "./src/user.ts",
      "default": "./dist/user.js"
    }
  },
  "devDependencies": {
    "typescript": "~5.8.3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.51.0"
  }
}