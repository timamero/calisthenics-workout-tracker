{
  "name": "@cwt/mocks",
  "version": "0.1.0-alpha.1",
  "private": true,
  "description": "CWT Mocks for development and testing",
  "type": "module",
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc"
  },
  "exports": {
    "./sampleExercises": {
      "types": "./dist/sampleExercises.d.ts",
      "default": "./dist/sampleExercises.js"
    },
    "./sampleWorkoutBuilds": {
      "types": "./dist/sampleWorkoutBuilds.d.ts",
      "default": "./dist/sampleWorkoutBuilds.js"
    },
    "./sampleWorkoutLogs": {
      "types": "./dist/sampleWorkoutLogs.d.ts",
      "default": "./dist/sampleWorkoutLogs.js"
    }
  },
  "dependencies": {
    "@cwt/schema": "workspace:*"
  },
  "devDependencies": {
    "typescript": "~5.8.3"
  }
}
