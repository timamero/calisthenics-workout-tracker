{
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"build:web": "turbo run build --filter=web",
		"build:state": "turbo run build --filter=@cwt/state",
		"build:schema": "turbo run build --filter=@cwt/schema",
		"lint": "turbo run lint",
		"dev": "turbo run dev",
		"dev:backend": "turbo run dev --filter=backend",
		"dev:web": "turbo run dev --filter=web",
		"dev:mobile": "turbo run dev --filter=mobile",
		"dev:web+backend": "turbo run dev --filter=web --filter=backend",
		"dev:mobile+backend": "turbo run dev --filter=mobile --filter=backend",
		"test": "turbo run test",
		"test:watch": "turbo run test:watch",
		"test:web": "vitest",
		"prepare": "husky"
	},
	"devDependencies": {
		"husky": "^9.1.7",
		"turbo": "^2.5.3"
	},
	"packageManager": "pnpm@10.12.2"
}
