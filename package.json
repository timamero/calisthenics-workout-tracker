{
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@cwt/web",
    "build:api": "turbo run build --filter=@cwt/api",
    "build:auth": "turbo run build --filter=@cwt/auth",
    "build:content": "turbo run build --filter=@cwt/content",
    "build:context": "turbo run build --filter=@cwt/context",
    "build:hooks": "turbo run build --filter=@cwt/hooks",
    "build:mocks": "turbo run build --filter=@cwt/mocks",
    "build:schema": "turbo run build --filter=@cwt/schema",
    "build:state": "turbo run build --filter=@cwt/state",
    "build:utils": "turbo run build --filter=@cwt/utils",
    "build:packages": "pnpm build:api && pnpm build:auth && pnpm build:content && pnpm build:context && pnpm build:hooks && pnpm build:mocks && pnpm build:schema && pnpm build:state && pnpm build:utils",
    "lint": "turbo run lint",
    "dev": "turbo run dev",
    "dev:backend": "turbo run dev --filter=@cwt/backend",
    "dev:web": "turbo run dev --filter=@cwt/web",
    "dev:mobile": "turbo run dev --filter=@cwt/mobile",
    "dev:web+backend": "turbo run dev --filter=@cwt/web --filter=@cwt/backend",
    "dev:mobile+backend": "turbo run dev --filter=@cwt/mobile --filter=@cwt/backend",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:web": "vitest",
    "prepare": "husky",
    "setup-backend": "turbo run install --filter=@cwt/backend",
    "supabase-login": "supabase login",
    "expo-build:development": "eas build --platform android --profile development --project apps/frontend/mobile",
    "expo-build:preview": "eas build --platform android --profile preview --project apps/frontend/mobile",
    "generate-schema-types": "supabase gen types --project-id ocdfgrsizsxyltygfpje --schema public > packages/schema/src/lib/common/database.types.ts"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "supabase": "^2.84.7",
    "turbo": "^2.9.3"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "@types/react": "~19.1.10",
      "vite@>=6.0.0 <=6.4.0": ">=6.4.1",
      "vite@>=7.1.0 <=7.1.10": ">=7.1.11",
      "js-yaml@<3.14.2": ">=3.14.2",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "node-forge@<1.3.2": ">=1.3.2",
      "react-server-dom-webpack@=19.0.0": ">=19.0.1",
      "react-server-dom-webpack@>=19.0.0 <19.0.2": ">=19.0.2",
      "react-server-dom-webpack@>=19.1.0 <19.1.1": ">=19.1.1"
    },
    "onlyBuiltDependencies": [
      "supabase"
    ]
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
