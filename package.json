{
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@cwt/web",
    "build:web:staging": "turbo run build:staging --filter=@cwt/web",
    "build:web:production": "turbo run build:production --filter=@cwt/web",
    "build:api": "turbo run build --filter=@cwt/api",
    "build:auth": "turbo run build --filter=@cwt/auth",
    "build:content": "turbo run build --filter=@cwt/content",
    "build:context": "turbo run build --filter=@cwt/context",
    "build:hooks": "turbo run build --filter=@cwt/hooks",
    "build:mocks": "turbo run build --filter=@cwt/mocks",
    "build:schema": "turbo run build --filter=@cwt/schema",
    "build:state": "turbo run build --filter=@cwt/state",
    "build:utils": "turbo run build --filter=@cwt/utils",
    "build:packages": "pnpm build:api && pnpm build:auth && pnpm build:content && pnpm build:context && pnpm build:hooks && pnpm build:mocks && pnpm build:schema && pnpm build:state && pnpm build:utils",
    "lint": "turbo run lint",
    "dev": "turbo run dev",
    "dev:backend": "turbo run dev --filter=@cwt/backend",
