{
	"private": true,
	"scripts": {
		"build": "turbo run build",
    "build-web": "turbo run build --filter=web",
		"lint": "turbo run lint",
		"dev": "turbo run dev",
		"dev:backend": "turbo run dev --filter=backend",
		"dev:web": "turbo run dev --filter=web",
		"dev:mobile": "turbo run dev --filter=mobile",
		"dev:web+backend": "turbo run dev --filter=web --filter=backend",
		"dev:mobile+backend": "turbo run dev --filter=mobile --filter=backend",
		"docker:web:build": "docker build -f apps/frontend/web/Dockerfile.dev -t calisthenics-web-dev .",
		"docker:web:run": "docker run --rm -it -p 8081:8081 -p 19000:19000 -p 19001:19001 -v $(pwd):/workspace -w /web calisthenics-web-dev",
		"docker:backend:build": "docker build -f apps/backend/Dockerfile.dev -t calisthenics-backend-dev ./apps/backend",
		"docker:backend:run": "docker run --rm -it -p 8081:8081 -p 19000:19000 -p 19001:19001 -v $(pwd):/workspace -w /backend calisthenics-backend-dev",
		"docker-build-all": "pnpm docker:web:build; pnpm docker:backend:build",
		"web-build": "turbo run build --filter=web",
		"prepare": "husky"
	},
	"devDependencies": {
		"husky": "^9.1.7",
		"turbo": "^2.5.3"
	},
	"packageManager": "pnpm@10.11.1"
}
